{
  "name": "bungoma-poly-verify",
  "version": "1.0.0",
  "private": true,
  "description": "Official Certificate Verification System for Bungoma National Polytechnic",
  "main": "api/index.js",
  "scripts": {
    "dev": "vercel dev",
    "generate": "drizzle-kit generate:sqlite",
    "push": "drizzle-kit push:sqlite",
    "seed": "node lib/db/seed.js",
    "build": "cd client && npm install --legacy-peer-deps && npm run build",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@libsql/client": "^0.6.0",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^5.5.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "formidable": "^3.5.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.13",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.21.4",
    "vercel": "^34.1.3"
  }
}
