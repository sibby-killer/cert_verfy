{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/admin/:path*",
      "destination": "/api/admin.js?path=:path"
    },
    {
      "source": "/api/verify/:path*",
      "destination": "/api/verify.js?path=:path"
    },
    {
      "source": "/api/report",
      "destination": "/api/verify.js?path=report"
    },
    {
      "source": "/(.*)",
      "destination": "/client/index.html"
    }
  ]
}
